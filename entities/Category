{
  "name": "Category",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Category name"
    },
    "type": {
      "type": "string",
      "enum": [
        "income",
        "expense",
        "savings",
        "debt"
      ],
      "description": "Category type"
    },
    "icon": {
      "type": "string",
      "description": "Icon name from lucide"
    },
    "color": {
      "type": "string",
      "description": "Hex color for the category"
    },
    "parent_id": {
      "type": "string",
      "description": "Parent category ID for subcategories"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    },
    "is_archived": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "name",
    "type"
  ]
}